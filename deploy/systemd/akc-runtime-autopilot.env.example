# AKC_INGEST_STATE_PATH=/var/lib/akc/ingest_state.json
# AKC_TENANT_ID=example-tenant
# AKC_REPO_ID=example-repo
# AKC_AUTOPILOT_LEASE_BACKEND=filesystem
# AKC_AUTOPILOT_EXPECT_REPLICAS=1
